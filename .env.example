# ══════════════════════════════════════════════════════════════════════════════
# NİDAH GROUP — Environment Variables
# Copy this file to .env.local for local development.
# Set all REQUIRED variables in Vercel dashboard for production.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Neon PostgreSQL serverless connection string.
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Admin Authentication (REQUIRED) ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# JWT signing secret — minimum 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Email / Resend (REQUIRED for email notifications) ────────────────────────
# Get API key: https://resend.com/api-keys
# Sender domain must be verified in Resend: nidahgroup.com.tr
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Admin email that receives new RFQ notifications.
ADMIN_EMAIL=mustafa.koc@nidahgroup.com.tr

# ── Rate Limiting — Upstash Redis (REQUIRED in production) ───────────────────
# Without these, rate limiting falls back to in-memory (not safe on Vercel).
# Create a free Redis at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry (OPTIONAL — error monitoring) ─────────────────────────────────────
# Create a project at: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
# For source map uploads in CI builds:
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=nidah-group-web

# ── Cloudinary (REQUIRED for product photo management) ───────────────────────
# Create a free account: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Prosis Connector (OPTIONAL — live Oracle parts catalog) ──────────────────
# This service cannot run on Vercel (requires Oracle XE). Deploy it on a VPS
# and point to its public URL.
PROSIS_CONNECTOR_URL=http://localhost:7001
# Production: PROSIS_CONNECTOR_URL=https://prosis.nidahgroup.com.tr
