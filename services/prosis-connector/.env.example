# Oracle connection (Prosis)
ORACLE_USER=PROSIS
ORACLE_PASSWORD=PROSIS
ORACLE_DSN=localhost:1521/xe

# Path to Oracle Instant Client directory (required for thick mode / 11g)
# Download from: https://www.oracle.com/database/technologies/instant-client/winx64-64-downloads.html
# Example: C:\oracle\instantclient_21_15
ORACLE_LIB_DIR=C:\oracle\instantclient_21_15

# Service settings
SERVICE_PORT=7001
CORS_ORIGINS=http://localhost:3000,https://www.nidahismak.com

# Cache TTL in seconds (how long to keep search results cached)
CACHE_TTL_SECONDS=300

# Rate limiting — max requests per IP per minute
RATE_LIMIT_PER_MINUTE=60

# Hard upper bound on returned rows (safety net)
MAX_ROWS=500
